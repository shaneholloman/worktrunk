[107m [0m [2m#[0m
[107m [0m [2m# [commit.generation][0m
[107m [0m [2m# command = "MAX_THINKING_TOKENS=0 claude -p --no-session-persistence --model=haiku --tools='' --disable-slash-commands --setting-sources='' --system-prompt=''"[0m
[107m [0m [2m#[0m
